generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  passwordHash  String?
  image         String?
  platformRole  PlatformRole @default(USER)
  emailVerified DateTime?
  deletedAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  accounts            Account[]
  memberships         Membership[]
  sessions            Session[]
  auditLogs           AuditLog[]
  passwordResetTokens PasswordResetToken[]
  sentInvites         WorkspaceInvite[]    @relation("WorkspaceInviteInviter")
  betaFeedbacks       BetaFeedback[]
}

enum PlatformRole {
  USER
  W3_ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
  sessionToken String   @unique
  createdAt    DateTime @default(now())
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Workspace {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  plan      WorkspacePlan @default(FREE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  memberships              Membership[]
  connectors               ConnectorAccount[]
  connectorProviderConfigs ConnectorProviderConfig[]
  dashboards               Dashboard[]
  dailyMetrics             DailyMetric[]
  auditLogs                AuditLog[]
  invites                  WorkspaceInvite[]
  betaFeedbacks            BetaFeedback[]
}

enum WorkspacePlan {
  FREE
  PRO
  AGENCY
}

model Membership {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role        MemberRole
  createdAt   DateTime   @default(now())

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model WorkspaceInvite {
  id          String     @id @default(cuid())
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String
  role        MemberRole
  token       String     @unique
  invitedById String
  invitedBy   User       @relation("WorkspaceInviteInviter", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime   @default(now())

  @@index([workspaceId])
  @@index([email])
}

enum MemberRole {
  OWNER
  ADMIN
  VIEWER
}

model ConnectorAccount {
  id                        String            @id @default(cuid())
  workspaceId               String
  workspace                 Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  provider                  ConnectorProvider
  externalAccountId         String
  accountName               String
  status                    ConnectorStatus   @default(ACTIVE)
  accessTokenCiphertext     String
  refreshTokenCiphertext    String?
  tokenIv                   String
  tokenAuthTag              String
  tokenKeyVersion           String            @default("v1")
  credentialSecretId        String?
  refreshCredentialSecretId String?
  tokenExpiresAt            DateTime?
  metadata                  Json?
  lastSyncedAt              DateTime?
  lastSyncError             String?
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt

  @@unique([workspaceId, provider, externalAccountId])
  @@index([workspaceId, provider])
}

model ConnectorProviderConfig {
  id                  String                        @id @default(cuid())
  workspaceId         String
  workspace           Workspace                     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  provider            ConnectorProvider
  status              ConnectorProviderConfigStatus @default(ACTIVE)
  redirectUri         String?
  scopes              String?
  apiVersion          String?
  baseUrl             String?
  ordersPath          String?
  displayName         String?
  publicCredentials   Json?
  secretRefs          Json?
  lastValidatedAt     DateTime?
  lastValidationError String?
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt

  @@unique([workspaceId, provider])
  @@index([workspaceId, status])
}

enum ConnectorProviderConfigStatus {
  ACTIVE
  INACTIVE
  ERROR
}

model ConnectorSelectionSession {
  id                   String            @id @default(cuid())
  workspaceId          String
  userId               String
  provider             ConnectorProvider
  status               String            @default("PENDING")
  accounts             Json
  credentialCiphertext String
  credentialIv         String
  credentialAuthTag    String
  credentialKeyVersion String            @default("v1")
  credentialSecretId   String?
  expiresAt            DateTime
  consumedAt           DateTime?
  createdAt            DateTime          @default(now())

  @@index([workspaceId, userId, provider])
  @@index([expiresAt])
}

enum ConnectorProvider {
  META_ADS
  GOOGLE_ADS
  SHOPIFY
  NUVEMSHOP
  ISET
  TRAY
  WBUY
  MAGAZORD
  GA4
  SEARCH_CONSOLE
  TIKTOK_ADS
}

enum ConnectorStatus {
  ACTIVE
  TOKEN_EXPIRED
  REVOKED
  ERROR
}

model DailyMetric {
  id                 String            @id @default(cuid())
  workspaceId        String
  workspace          Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connectorAccountId String
  date               DateTime          @db.Date
  source             ConnectorProvider
  campaignId         String?
  campaignName       String?
  adsetId            String?
  adsetName          String?
  adId               String?
  spend              Decimal?          @db.Decimal(14, 2)
  impressions        BigInt?
  clicks             BigInt?
  conversions        Decimal?          @db.Decimal(14, 2)
  conversionsValue   Decimal?          @db.Decimal(14, 2)
  sessions           BigInt?
  orders             BigInt?
  revenue            Decimal?          @db.Decimal(14, 2)
  dedupeHash         String            @unique
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([workspaceId, date])
  @@index([workspaceId, source, date])
  @@index([workspaceId, campaignId, date])
}

model EcommerceOrder {
  id                 String            @id @default(cuid())
  workspaceId        String
  connectorAccountId String
  externalOrderId    String
  platform           ConnectorProvider
  orderNumber        String?
  customerEmail      String?
  orderTotal         Decimal           @db.Decimal(14, 2)
  orderCurrency      String            @default("BRL")
  itemsCount         Int
  status             String
  utmSource          String?
  utmMedium          String?
  utmCampaign        String?
  placedAt           DateTime
  createdAt          DateTime          @default(now())

  @@unique([connectorAccountId, externalOrderId])
  @@index([workspaceId, placedAt])
}

model Dashboard {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ownerId     String
  name        String
  isDefault   Boolean   @default(false)
  layout      Json
  widgets     Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
}

model AuditLog {
  id           String     @id @default(cuid())
  workspaceId  String?
  workspace    Workspace? @relation(fields: [workspaceId], references: [id])
  userId       String?
  user         User?      @relation(fields: [userId], references: [id])
  action       String
  resourceType String?
  resourceId   String?
  metadata     Json?
  ip           String?
  userAgent    String?
  createdAt    DateTime   @default(now())

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
}

model BetaFeedback {
  id          String             @id @default(cuid())
  workspaceId String?
  workspace   Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  type        BetaFeedbackType   @default(SUGGESTION)
  message     String             @db.Text
  pagePath    String?
  status      BetaFeedbackStatus @default(OPEN)
  metadata    Json?
  createdAt   DateTime           @default(now())

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

enum BetaFeedbackType {
  BUG
  SUGGESTION
  QUESTION
}

enum BetaFeedbackStatus {
  OPEN
  REVIEWED
  CLOSED
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model SyncJob {
  id                 String     @id @default(cuid())
  connectorAccountId String
  status             SyncStatus
  startedAt          DateTime   @default(now())
  finishedAt         DateTime?
  rowsInserted       Int        @default(0)
  rowsUpdated        Int        @default(0)
  errorMessage       String?
  metadata           Json?

  @@index([connectorAccountId, startedAt])
}

enum SyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}
